# Self-contained. Full style canon + repo deltas.
# shared-core v1 (2026-07) — sync: GhidraSharp <-> RomForge.Lab
root = true

[*]
charset = utf-8
insert_final_newline = true

[*.cs]
indent_style = space
indent_size = 4

# Surface every style rule as a build warning; specific rules are tuned below.
dotnet_analyzer_diagnostic.category-Style.severity = warning

# Modern idiom baseline — stated so escalation can't flip it.
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = true
csharp_style_namespace_declarations = file_scoped
csharp_style_prefer_top_level_statements = true
csharp_prefer_braces = true
dotnet_style_prefer_collection_expression = when_types_loosely_match
csharp_style_expression_bodied_methods = true
csharp_style_expression_bodied_operators = true
csharp_style_expression_bodied_properties = true
csharp_style_expression_bodied_indexers = true
csharp_style_expression_bodied_accessors = true
csharp_style_expression_bodied_lambdas = true
csharp_style_expression_bodied_local_functions = true

# Advisory-only: refactors these demand often read worse than what they replace.
dotnet_diagnostic.IDE0046.severity = suggestion
dotnet_diagnostic.IDE0058.severity = suggestion

# Legacy CLS-compliance attribute demand — meaningless for modern .NET-only code.
dotnet_diagnostic.CA1014.severity = none

[*.{json,yml,yaml,props,csproj,slnx,proto}]
indent_style = space
indent_size = 2

# xUnit conventions: Method_does_thing names (CA1707) and […]Collection fixture types (CA1711).
# NB both spellings — "**/tests/" alone does NOT match a repo-root tests/ folder.
[{tests,**/tests}/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.xUnit1051.severity = warning

# ---------- GhidraSharp deltas ----------
# XML docs are a contract for the published library only; sample/tests/bench are not shipped.
[{tests,bench}/**.cs]
dotnet_diagnostic.CS1591.severity = none

[src/GhidraSharp.Sample/**.cs]
dotnet_diagnostic.CS1591.severity = none
